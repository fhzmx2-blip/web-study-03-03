<!DOCTYPE configuration
  PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-config.dtd">
<!--  Connection 관련  -->
<configuration>
  <properties resource="db.properties"/>
  <settings>
    <setting name="cacheEnabled" value="true"/>
    <!-- 동일 쿼리를 반복 실행하면 DB를 다시 조회하지 않는다 -->
    <!-- <setting name="mapUnderscoreToCamelCase" value="true"/> -->
    <!-- 컬럼명 : user_name + userName -->
    <setting name="callSettersOnNulls" value="true"/>
    <!-- null값이 있는 경우 : setter호출 -->
    <setting name="logImpl" value="STDOUT_LOGGING"/>
    <!-- SQL실행 로그 출력 -->
  </settings>
  <typeAliases>
    <typeAlias type="com.sist.vo.MemberVO" alias="MemberVO"/>
    <typeAlias type="com.sist.vo.FoodVO" alias="FoodVO"/>
    <typeAlias type="com.sist.vo.TourVO" alias="TourVO"/>
    <typeAlias type="com.sist.vo.BoardVO" alias="BoardVO"/>
    <typeAlias type="com.sist.vo.ReviewVO" alias="ReviewVO"/>
    <typeAlias type="com.sist.vo.LikeVO" alias="LikeVO"/>
    <typeAlias type="com.sist.vo.NoticeVO" alias="NoticeVO"/>
    <typeAlias type="com.sist.vo.ReserveVO" alias="ReserveVO"/>
    <typeAlias type="com.sist.vo.GoodsVO" alias="GoodsVO"/>
  </typeAliases>
  <environments default="development">
    <environment id="development">
      <transactionManager type="JDBC"/>
      <dataSource type="POOLED">
       <!-- type : class명 PooledDataSource-->
       <property name="driver" value="${driver}"/>
       <property name="url" value="${url}"/>
       <property name="username" value="${username}"/>
       <property name="password" value="${password}"/>
       <property name="poolMaximumActiveConnections" value="${maxActive}"/>
       <property name="poolMaximumIdleConnections" value="${maxIdle}"/>
       <property name="poolTimeToWait" value="${maxWait}"/>
       <!-- 설정이 없는 경우 maxActive:8 / maxIdle:8 / maxWait:10000 -->
      </dataSource>
    </environment>
  </environments>
  <!-- 
      1. Table 제작 / Sequence = 이미 제작 
      2. VO 제작 
      3. mapper 제작 
      4. DAO 제작 
      5. Model 제작 
      6. JSP 출력 
         Spring / Spring-Boot
   -->
  <mappers>
    <mapper resource="com/sist/mapper/member-mapper.xml"/>
    <mapper resource="com/sist/mapper/food-mapper.xml"/>
    <mapper resource="com/sist/mapper/tour-mapper.xml"/>
    <mapper resource="com/sist/mapper/main-mapper.xml"/>
    <mapper resource="com/sist/mapper/board-mapper.xml"/>
    <mapper resource="com/sist/mapper/review-mapper.xml"/>
    <mapper resource="com/sist/mapper/like-mapper.xml"/>
    <mapper resource="com/sist/mapper/notice-mapper.xml"/>
    <mapper resource="com/sist/mapper/admin-mapper.xml"/>
    <mapper resource="com/sist/mapper/jjim-mapper.xml"/>
    <mapper resource="com/sist/mapper/reserve-mapper.xml"/>
    <mapper resource="com/sist/mapper/recommand-mapper.xml"/>
    <mapper resource="com/sist/mapper/goods-mapper.xml"/>
  </mappers>
</configuration>