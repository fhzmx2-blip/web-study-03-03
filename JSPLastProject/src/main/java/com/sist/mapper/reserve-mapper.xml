<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sist.mapper.reserve-mapper">
  <select id="reserveFoodListData" resultType="FoodVO"
  parameterType="hashmap">
    SELECT no,name,poster,type
    FROM food 
    WHERE type LIKE '%'||#{type}||'%'
    ORDER BY no ASC
    OFFSET #{start} ROWS FETCH NEXT 20 ROWS ONLY
  </select>
  <select id="reserveFoodTotalPage" resultType="int" parameterType="string">
    SELECT CEIL(COUNT(*)/20.0)
    FROM food 
    WHERE type LIKE '%'||#{type}||'%'
  </select>
  <!-- 
     RNO     NOT NULL NUMBER       
	 FNO              NUMBER       
	ID               VARCHAR2(20) 
	NAME    NOT NULL VARCHAR2(51) 
	RDATE   NOT NULL VARCHAR2(20) 
	RTIME   NOT NULL VARCHAR2(20) 
	INWON   NOT NULL VARCHAR2(20) 
	REGDATE          DATE         
	OK               CHAR(1)  
   -->
  <insert id="reserveInsert" parameterType="ReserveVO">
   INSERT INTO reserve(rno,fno,id,name,rdate,rtime,inwon)
   VALUES(res_rno_seq.nextval,#{fno},#{id},#{name},
   #{rdate},#{rtime},#{inwon})
  </insert>
  <!-- 
      ResultSet rs=ps.executeQuery()
      while(rs.next())
      {
         ReserveVO vo=new ReserveVO()
         vo.setRno(rs.getInt("rno"))
         vo.getFvo().setPhone(rs.getString("phone"))
         ====================              =======
           fvo.phone                       column
      }
   -->
  <resultMap type="com.sist.vo.ReserveVO" id="rMap">
    <result column="poster" property="fvo.poster"/>
    <result column="name" property="fvo.name"/>
    <result column="phone" property="fvo.phone"/>
  </resultMap>
  <select id="reservemyPageListData" parameterType="string"
    resultMap="rMap"
  >
    SELECT rno,fno,id,rdate,rtime,inwon,
           TO_CHAR(regdate,'yyyy-mm-dd') as dbday,
           poster,f.name,phone,ok
    FROM reserve r JOIN food f
    ON r.fno=f.no
    AND id=#{id}
    ORDER BY rno DESC
  </select>
  <!-- 
      승인 / 취소 / 예약정보 보기 = 알림 
   -->
  <select id="reserveAdminPageListData" resultMap="rMap"
  >
    SELECT rno,fno,id,r.name,rdate,rtime,inwon,
           TO_CHAR(regdate,'yyyy-mm-dd') as dbday,
           poster,f.name,phone,ok
    FROM reserve r JOIN food f
    ON r.fno=f.no
    ORDER BY rno DESC
  </select>
  
  <update id="reserveAdminOk" parameterType="int">
    UPDATE reserve SET
    ok='y'
    WHERE rno=#{rno}
  </update>
  <!--  예약 취소 -->
  <delete id="reserveDelete" parameterType="int">
   DELETE FROM reserve
   WHERE rno=#{rno}
  </delete>
  <!-- 예약 정보  -->
  <resultMap type="com.sist.vo.ReserveVO" id="infoMap">
    <result property="fvo.name" column="name"/>
    <result property="fvo.poster" column="poster"/>
    <!-- setter
         vo.getFvo().setPoster(rs.getString("poster"))
         vo.setPoster()
         
         @Results({}) 
     -->
    <result property="fvo.address" column="address"/>
    <result property="fvo.phone" column="phone"/>
    <result property="fvo.parking" column="parking"/>
    <result property="fvo.type" column="type"/>
    <result property="fvo.score" column="score"/>
    <result property="fvo.time" column="time"/>
  </resultMap>
  <select id="reserveInfoData" parameterType="int"
   resultMap="infoMap"
  >
    SELECT rno,no,rdate,rtime,inwon,address,phone,parking,poster,
           type,score,time,f.name
    FROM reserve r JOIN food f
    ON r.fno=f.no
    AND rno=#{rno}
  </select>
</mapper>

